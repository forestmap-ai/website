---
import { withBase } from '../lib/site';
interface Props {
  title: string;
  headline: string;
  sector: string;
  scale: string;
  href: string;
}
const { title, headline, sector, scale, href } = Astro.props;
---

<a
  href={withBase(href)}
  class="group flex h-full flex-col overflow-hidden rounded-3xl border border-forest-100 bg-white transition hover:-translate-y-1 hover:shadow-xl hover:shadow-forest-900/5"
>
  <div class="relative aspect-[16/9] overflow-hidden bg-forest-900">
    <div class="absolute inset-0 opacity-30" aria-hidden="true"
      style="background-image: radial-gradient(circle at 30% 30%, #22cc2e55, transparent 45%), radial-gradient(circle at 75% 70%, #7cc6ec55, transparent 45%);">
    </div>
    <div class="absolute inset-0 flex items-end p-5">
      <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-forest-800">{sector}</span>
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <p class="eyebrow">{title}</p>
    <h3 class="mt-2 text-lg font-semibold leading-snug text-forest-900">{headline}</h3>
    <p class="mt-3 text-sm text-forest-500">{scale}</p>
    <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-forest-700 group-hover:text-brand-green-dark">
      Read case study
      <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</a>
