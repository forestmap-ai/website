---
import { withBase } from '../lib/site';
interface Props {
  name: string;
  headline: string;
  summary: string;
  href: string;
}
const { name, headline, summary, href } = Astro.props;
---

<a
  href={withBase(href)}
  class="group flex h-full flex-col rounded-3xl border border-forest-100 bg-white p-7 transition hover:-translate-y-1 hover:border-brand-green/50 hover:shadow-xl hover:shadow-forest-900/5"
>
  <p class="eyebrow">{name}</p>
  <h3 class="mt-3 text-xl font-semibold leading-snug text-forest-900">{headline}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-forest-600">{summary}</p>
  <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-forest-700 group-hover:text-brand-green-dark">
    Learn more
    <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
