---
import { testimonials } from '../lib/site';
---

<div class="grid gap-6 md:grid-cols-3">
  {
    testimonials.map((t) => (
      <figure class="flex h-full flex-col rounded-3xl border border-forest-100 bg-white p-7">
        <svg class="h-7 w-7 text-brand-green" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M10 7H6a3 3 0 0 0-3 3v7h7v-7H6.5A3.5 3.5 0 0 1 10 6.5V7Zm11 0h-4a3 3 0 0 0-3 3v7h7v-7h-3.5A3.5 3.5 0 0 1 21 6.5V7Z" />
        </svg>
        <blockquote class="mt-4 flex-1 text-base leading-relaxed text-forest-800">{t.quote}</blockquote>
        <figcaption class="mt-5 border-t border-forest-100 pt-4">
          <div class="font-semibold text-forest-900">{t.name}</div>
          <div class="text-sm text-forest-500">{t.role}</div>
        </figcaption>
      </figure>
    ))
  }
</div>
