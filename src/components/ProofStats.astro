---
import { proofPoints } from '../lib/site';
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {
    proofPoints.map((p) => (
      <div class="rounded-3xl border border-forest-100 bg-forest-50/60 p-6">
        <div class="font-display text-2xl font-semibold text-brand-green-dark">{p.stat}</div>
        <p class="mt-2 text-sm leading-relaxed text-forest-700">{p.label}</p>
      </div>
    ))
  }
</div>
