---
import { nav, withBase } from '../lib/site';

const current = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string) {
  const target = withBase(href).replace(/\/$/, '');
  if (href === '/') return current === target;
  return current === target || current.startsWith(target + '/');
}
---

<header class="sticky top-0 z-50 border-b border-forest-100 bg-white/90 backdrop-blur">
  <div class="container-content flex h-16 items-center justify-between gap-4">
    <a href={withBase('/')} class="flex shrink-0 items-center" aria-label="forestmap.ai home">
      <img src={withBase('/brand/logo.png')} alt="forestmap.ai" class="h-8 w-auto" />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        nav.map((item) =>
          item.children ? (
            <div class="group relative">
              <a
                href={withBase(item.href)}
                class:list={[
                  'flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium transition',
                  isActive(item.href) ? 'text-forest-900' : 'text-forest-600 hover:text-forest-900',
                ]}
              >
                {item.label}
                <svg class="h-3 w-3 opacity-60" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
              <div class="invisible absolute left-0 top-full pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100">
                <div class="min-w-56 rounded-2xl border border-forest-100 bg-white p-2 shadow-lg shadow-forest-900/5">
                  {item.children.map((child) => (
                    <a
                      href={withBase(child.href)}
                      class="block rounded-xl px-3 py-2 text-sm text-forest-700 hover:bg-forest-50 hover:text-forest-900"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.external ? item.href : withBase(item.href)}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener' : undefined}
              class:list={[
                'rounded-full px-3 py-2 text-sm font-medium transition',
                isActive(item.href) ? 'text-forest-900' : 'text-forest-600 hover:text-forest-900',
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <a href={withBase('/contact')} class="btn-accent hidden text-xs lg:inline-flex">Get in touch</a>

    <details class="lg:hidden">
      <summary class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-forest-200 text-forest-700 [&::-webkit-details-marker]:hidden">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span class="sr-only">Open menu</span>
      </summary>
      <div class="absolute left-0 right-0 top-16 border-b border-forest-100 bg-white px-5 py-4 shadow-lg">
        <nav class="flex flex-col gap-1" aria-label="Mobile">
          {
            nav.map((item) => (
              <div>
                <a
                  href={item.external ? item.href : withBase(item.href)}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener' : undefined}
                  class="block rounded-lg px-3 py-2 text-sm font-semibold text-forest-900 hover:bg-forest-50"
                >
                  {item.label}
                </a>
                {item.children && (
                  <div class="ml-3 flex flex-col border-l border-forest-100 pl-3">
                    {item.children.map((child) => (
                      <a href={withBase(child.href)} class="block rounded-lg px-3 py-1.5 text-sm text-forest-600 hover:bg-forest-50">
                        {child.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
          <a href={withBase('/contact')} class="btn-accent mt-3 text-xs">Get in touch</a>
        </nav>
      </div>
    </details>
  </div>
</header>
