---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/site';
---

<Base title="Page not found" description="The page you were looking for could not be found.">
  <section class="bg-forest-950 text-white">
    <div class="container-content flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <p class="font-display text-6xl font-semibold text-brand-green">404</p>
      <h1 class="mt-4 text-3xl font-semibold text-white">This trail doesn't lead anywhere.</h1>
      <p class="mt-3 max-w-md text-forest-300">
        The page you were looking for has moved or never existed. Let's get you back on track.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={withBase('/')} class="btn-accent">Back to home</a>
        <a href={withBase('/work')} class="btn-ghost-light">See our work</a>
      </div>
    </div>
  </section>
</Base>
