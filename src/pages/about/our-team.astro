---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import CTA from '../../components/CTA.astro';
import { withBase } from '../../lib/site';

const founder = {
  name: 'Dr James Ball',
  role: 'Founder & CEO',
  photo: '/photos/james-ball.jpg',
  bio: "James' research integrates remote sensing, tropical ecology, and artificial intelligence to map, monitor and forecast biodiversity in some of the world's most complex forest landscapes. Alongside deep technical expertise in machine learning and geospatial analysis, he brings extensive on-the-ground experience from field campaigns across Southeast Asia, South America, and Africa. His work bridges cutting-edge science with real-world conservation challenges, helping organisations develop AI-driven solutions to protect forests and respond to the climate crisis.",
  links: [
    { label: 'detectree2', href: 'https://github.com/PatBall1/detectree2' },
  ],
};

const team = [
  {
    name: 'Christopher Kotthoff',
    role: 'Senior Computer Vision Consultant',
    photo: '/photos/christopher-kotthoff.jpg',
    bio: "Christopher is a computer scientist specialising in applying modern computer vision to aerial forest imagery, with a focus on automated tree mapping and ecological monitoring. He completed his MSc in Computer Science at ETH Zurich, carrying out his thesis at Cambridge, where he developed deep-learning methods for tree detection and contributed to the detectree2 open-source project. Alongside his academic work, he has led software efforts in high-performance engineering teams and AI start-ups. At forestmap.ai, he supports our advanced modelling pipeline and brings cutting-edge computer vision expertise to large-scale forest analysis.",
    links: [
      { label: 'detectree2', href: 'https://github.com/PatBall1/detectree2' },
    ],
  },
  {
    name: 'Kingston Kingsley',
    role: 'Data Scientist & Science Communications',
    photo: '',
    bio: "Kingston pairs quantitative modelling with a rare ability to make complex science clear. A physicist by training - with a First-Class degree in Physics and Philosophy and an MPhil at the University of Cambridge, where he modelled James Webb Space Telescope data using Bayesian inference and statistical methods in Python - he moved into data science via climate and sustainability work. After years as a scientific editor and writer, he helps forestmap.ai turn technical forest-AI work into insights that clients, partners, and wider audiences can act on, while supporting our data analysis and visualisation.",
    links: [],
  },
];
---

<Base title="Our Team" description="The ecologists, engineers, and computer-vision scientists behind forestmap.ai.">
  <Hero
    eyebrow="Our Team"
    title="Ecologists and engineers who build what they publish."
    lead="Our capabilities trace back to peer-reviewed research by the founding team - which matters when outputs need to be defensible under audit, regulatory scrutiny, or scientific review."
  />

  <Section>
    <div class="grid gap-8 lg:grid-cols-[auto_1fr] lg:items-start">
      <div class="mx-auto w-full max-w-xs lg:mx-0">
        <img
          src={withBase(founder.photo)}
          alt={`${founder.name}, ${founder.role} of forestmap.ai`}
          width="400"
          height="400"
          class="aspect-square w-full rounded-3xl object-cover"
        />
      </div>
      <div>
        <p class="eyebrow">Founder</p>
        <h2 class="mt-2 text-2xl font-semibold text-forest-900 sm:text-3xl">{founder.name}</h2>
        <p class="mt-1 text-sm font-medium text-forest-500">{founder.role}</p>
        <p class="mt-5 max-w-2xl leading-relaxed text-forest-600">{founder.bio}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            founder.links.map((l) => (
              <a
                href={l.href}
                target="_blank"
                rel="noopener"
                class="rounded-full bg-forest-50 px-3 py-1.5 text-xs font-semibold text-forest-700 hover:bg-forest-100"
              >
                {l.label} &nearr;
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </Section>

  <Section tone="tint">
    <div class="max-w-2xl">
      <p class="eyebrow">The team</p>
      <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Engineers and scientists behind the work.</h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        team.map((m) => (
          <div class="flex h-full flex-col rounded-3xl border border-forest-100 bg-white p-7">
            <div class="flex items-center gap-4">
              {
                m.photo ? (
                  <img
                    src={withBase(m.photo)}
                    alt={`${m.name}, ${m.role} at forestmap.ai`}
                    width="64"
                    height="64"
                    loading="lazy"
                    class="h-16 w-16 shrink-0 rounded-full object-cover"
                  />
                ) : (
                  <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-forest-900 font-display text-lg font-semibold text-brand-green">
                    {m.name.split(' ').filter((p) => !p.startsWith('Dr')).slice(0, 2).map((p) => p[0]).join('')}
                  </div>
                )
              }
              <div>
                <h3 class="text-lg font-semibold text-forest-900">{m.name}</h3>
                <p class="text-sm font-medium text-forest-500">{m.role}</p>
              </div>
            </div>
            <p class="mt-5 flex-1 text-sm leading-relaxed text-forest-600">{m.bio}</p>
            {
              m.links.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-2 border-t border-forest-100 pt-4">
                  {m.links.map((l) => (
                    <a
                      href={l.href}
                      target="_blank"
                      rel="noopener"
                      class="rounded-full bg-forest-50 px-3 py-1.5 text-xs font-semibold text-forest-700 hover:bg-forest-100"
                    >
                      {l.label} &nearr;
                    </a>
                  ))}
                </div>
              )
            }
          </div>
        ))
      }
    </div>
  </Section>

  <Section>
    <div class="max-w-2xl">
      <p class="eyebrow">In the field</p>
      <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Grounded in real forests.</h2>
      <p class="mt-4 text-lg text-forest-600">
        Our models are trained and validated against field-based ecological data - from canopy access
        and tree-climbing surveys to drone campaigns in remote terrain. That hands-on experience is
        what keeps the science honest.
      </p>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      <img src={withBase('/photos/tree-climb.jpg')} alt="James Ball carrying out canopy-access fieldwork" loading="lazy" class="h-64 w-full rounded-3xl object-cover" />
      <img src={withBase('/photos/tree-climb-2.jpg')} alt="James Ball climbing a forest canopy tree" loading="lazy" class="h-64 w-full rounded-3xl object-cover" />
      <img src={withBase('/photos/fieldwork-drone.jpg')} alt="James Ball demonstrating drone survey techniques to the field team in Harapan, Indonesia" loading="lazy" class="h-64 w-full rounded-3xl object-cover" />
    </div>
  </Section>

  <CTA
    title="Want to work with us?"
    text="Whether you're scoping a project or exploring a partnership, we'd like to hear from you."
    secondaryLabel="See our work"
    secondaryHref="/work"
  />
</Base>
