---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTA from '../../components/CTA.astro';

const caseStudies = (await getCollection('caseStudies')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Our Work" description="Case studies across carbon markets, island conservation, and urban forestry.">
  <Hero
    eyebrow="Our Work"
    title="The same approach, proven across scales and sectors."
    lead="From continental REDD+ jurisdictions to a single island to city streets - forestmap.ai turns complex remote sensing data into ecological intelligence that drives real decisions. We are not a one-trick research lab."
  />

  <Section>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        caseStudies.map((cs) => (
          <CaseStudyCard
            title={cs.data.title}
            headline={cs.data.headline}
            sector={cs.data.sector}
            scale={cs.data.scale}
            href={`/work/${cs.id}`}
          />
        ))
      }
    </div>
  </Section>

  <Section tone="tint">
    <div class="max-w-2xl">
      <p class="eyebrow">How these cases work together</p>
      <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">One core capability, many contexts.</h2>
    </div>
    <div class="mt-8 overflow-hidden rounded-3xl border border-forest-100 bg-white">
      <table class="w-full text-left text-sm">
        <thead class="bg-forest-50 text-forest-700">
          <tr>
            <th class="px-5 py-4 font-semibold">Dimension</th>
            <th class="px-5 py-4 font-semibold">Wildlife Works</th>
            <th class="px-5 py-4 font-semibold">Faya Foundation</th>
            <th class="px-5 py-4 font-semibold">BaKIM / Bamberg</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-forest-100 text-forest-700">
          <tr>
            <td class="px-5 py-4 font-medium text-forest-900">Scale</td>
            <td class="px-5 py-4">Continental (REDD+)</td>
            <td class="px-5 py-4">Island-wide</td>
            <td class="px-5 py-4">City-wide + expanding</td>
          </tr>
          <tr>
            <td class="px-5 py-4 font-medium text-forest-900">Sector</td>
            <td class="px-5 py-4">Carbon markets</td>
            <td class="px-5 py-4">Conservation</td>
            <td class="px-5 py-4">Urban forestry</td>
          </tr>
          <tr>
            <td class="px-5 py-4 font-medium text-forest-900">Output</td>
            <td class="px-5 py-4">Production forecasting system</td>
            <td class="px-5 py-4">Ecological baseline inventory</td>
            <td class="px-5 py-4">Web application</td>
          </tr>
        </tbody>
      </table>
    </div>
  </Section>

  <CTA />
</Base>
